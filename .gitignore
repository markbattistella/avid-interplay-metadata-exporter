# macOS
.DS_Store
**/.DS_Store

# Python
__pycache__/
*.pyc
*.pyo

# Virtual environments
app/.venv/

# Build-time version stamp (generated by build.py)
app/_version.py

# PyInstaller output
app/build/
app/dist/
app/*.spec

# Icon files (binary, add locally before building)
app/assets/*.icns
app/assets/*.ico

# Legacy folder (old app + screenshots — excluded from source control)
legacy/
